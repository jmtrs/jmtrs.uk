{
  "name": "jmtrs.uk",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "ASTRO_TELEMETRY_DISABLED=1 astro dev",
    "dev:poll": "ASTRO_TELEMETRY_DISABLED=1 ASTRO_USE_POLLING=1 astro dev",
    "start": "ASTRO_TELEMETRY_DISABLED=1 astro dev",
    "build": "node scripts/ensure-playwright-browser.mjs && ASTRO_TELEMETRY_DISABLED=1 astro build && node scripts/inline-css.mjs && node scripts/generate-seo-artifacts.mjs && node scripts/generate-cv-pdfs.mjs",
    "preview": "ASTRO_TELEMETRY_DISABLED=1 astro preview",
    "lint": "prettier --check .",
    "typecheck": "ASTRO_TELEMETRY_DISABLED=1 astro check",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@fontsource-variable/plus-jakarta-sans": "^5.2.8",
    "@fontsource/geist-mono": "^5.2.7",
    "@fontsource/manrope": "^5.2.6",
    "astro": "^6.3.1"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "playwright": "^1.59.1",
    "prettier": "^3.5.3",
    "prettier-plugin-astro": "^0.14.1",
    "typescript": "^5.8.3"
  }
}
