---
import "./SectionHeading.css";

interface Props {
  eyebrow: string;
  title: string;
  intro?: string;
  number?: string;
}

const { eyebrow, title, intro, number } = Astro.props;
---

<div class="section-heading reveal">
  {number && <span class="section-number" aria-hidden="true">{number}</span>}
  <p class="section-eyebrow">{eyebrow}</p>
  <h2>{title}</h2>
  {intro && <p class="section-intro">{intro}</p>}
</div>
