---
import "./ProjectCard.css";
import type { ProjectItem } from "../content/types";

interface Props {
  project: ProjectItem;
}

const { project } = Astro.props;
---

<article class="project-card reveal">
  <h3>{project.title}</h3>
  <p>{project.description}</p>
  <ul class="tag-list">
    {project.tags.map((tag) => <li>{tag}</li>)}
  </ul>
</article>
