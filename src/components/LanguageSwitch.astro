---
import "./LanguageSwitch.css";
import type { Locale } from "../content/site";

interface Props {
  locale: Locale;
  label: string;
}

const { locale, label } = Astro.props;
---

<nav
  class="locale-switch"
  aria-label={label}
  data-locale-switch
  data-current-locale={locale}
>
  <span class="locale-switch-icon" aria-hidden="true">
    <svg viewBox="0 0 24 24" focusable="false">
      <path
        d="M12 3.25a8.75 8.75 0 1 0 0 17.5 8.75 8.75 0 0 0 0-17.5Z"
        fill="none"
        stroke="currentColor"
        stroke-width="1.7"></path>
      <path
        d="M4.75 12h14.5M12 3.75c2.2 2.1 3.45 5.1 3.45 8.25S14.2 18.15 12 20.25M12 3.75c-2.2 2.1-3.45 5.1-3.45 8.25S9.8 18.15 12 20.25"
        fill="none"
        stroke="currentColor"
        stroke-linecap="round"
        stroke-width="1.7"></path>
    </svg>
  </span>
  <span class="locale-switch-options">
    <a
      href="/en"
      data-locale-link
      data-locale="en"
      data-locale-option
      aria-current={locale === "en" ? "page" : undefined}
    >
      EN
    </a>
    <a
      href="/es"
      data-locale-link
      data-locale="es"
      data-locale-option
      aria-current={locale === "es" ? "page" : undefined}
    >
      ES
    </a>
  </span>
</nav>
