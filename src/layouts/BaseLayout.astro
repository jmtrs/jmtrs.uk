---
import { ViewTransitions } from "astro:transitions";
import DownloadIcon from "../components/DownloadIcon.astro";
import LanguageSwitch from "../components/LanguageSwitch.astro";
import ThemeToggle from "../components/ThemeToggle.astro";
import type { Locale, SiteCopy } from "../content/site";
import { personSchema } from "../content/site";
import "../styles/global.css";
import "../styles/layout.css";
import "../styles/header-controls.css";
import "../styles/utilities.css";

interface Props {
  copy: SiteCopy;
  locale: Locale;
}

const { copy, locale } = Astro.props;
const currentYear = new Date().getFullYear();
const canonical = locale === "en" ? "/en" : "/es";
const siteUrl = Astro.site ?? new URL("https://jmtrs.uk");
const cvLinkTarget = "_blank";
const cvLinkRel = "noreferrer";
const englishUrl = new URL("/en", siteUrl);
const spanishUrl = new URL("/es", siteUrl);
const canonicalUrl = new URL(canonical, siteUrl);
const ogImage = new URL("/social-preview.svg", siteUrl);
const schema = {
  ...personSchema,
  url: siteUrl.toString(),
  homeLocation: {
    "@type": "Place",
    name: locale === "en" ? "Valencia, Spain" : "Valencia, España",
  },
};
---

<!doctype html>
<html lang={locale} data-theme="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={copy.description} />
    <meta name="theme-color" content="#050505" />
    <meta name="color-scheme" content="dark light" />
    <title>{copy.pageTitle}</title>
    <link rel="canonical" href={canonicalUrl} />
    <link rel="alternate" hreflang="en" href={englishUrl} />
    <link rel="alternate" hreflang="es" href={spanishUrl} />
    <link rel="alternate" hreflang="x-default" href={englishUrl} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={copy.pageTitle} />
    <meta property="og:description" content={copy.description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:locale" content={copy.ogLocale} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={copy.pageTitle} />
    <meta name="twitter:description" content={copy.description} />
    <meta name="twitter:image" content={ogImage} />
    <script is:inline>
      (() => {
        const themeKey = "jmtrs-theme";
        const storedTheme = window.localStorage.getItem(themeKey);
        const theme =
          storedTheme === "light" || storedTheme === "dark"
            ? storedTheme
            : window.matchMedia("(prefers-color-scheme: light)").matches
              ? "light"
              : "dark";
        document.documentElement.dataset.theme = theme;
      })();
    </script>
    <script
      is:inline
      type="application/ld+json"
      set:html={JSON.stringify(schema)}
    />
    <ViewTransitions />
  </head>
  <body>
    <a class="skip-link" href="#content">{copy.skipToContent}</a>
    <div class="site-shell">
      <header
        class:list={[
          "site-header",
          { "has-nav": copy.nav.length > 0, "no-nav": copy.nav.length === 0 },
        ]}
      >
        <a class="brand reveal" href={canonical} style="--delay: 40ms;">
          <span class="brand-mark">
            <img src="/logo.svg" alt="" aria-hidden="true" class="brand-logo" width="32" height="32" />
          </span>
          <span class="brand-copy">
            <strong>José Miguel Torres Hernández</strong>
            <span>Senior Software Engineer</span>
          </span>
        </a>

        {
          copy.nav.length > 0 && (
            <nav
              class="site-nav reveal"
              aria-label="Primary"
              style="--delay: 120ms;"
            >
              {copy.nav.map((item) => (
                <a href={item.href}>{item.label}</a>
              ))}
            </nav>
          )
        }

        <div class="header-actions reveal" style="--delay: 180ms;">
          <LanguageSwitch transition:persist="locale-switch-main" locale={locale} label={copy.languageSwitcherLabel} />
          <ThemeToggle themeLabel={copy.themeLabel} initialTheme="dark" />
          <a
            class="header-download"
            href={copy.headerCtaHref}
            target={cvLinkTarget}
            rel={cvLinkRel}
          >
            <DownloadIcon />
            <span class="header-download-label">{copy.headerCta}</span>
          </a>
          <button
            class="menu-toggle"
            type="button"
            data-menu-toggle
            aria-expanded="false"
            aria-controls="mobile-menu"
            aria-label={copy.menuLabel}
          >
            <span class="menu-toggle-box" aria-hidden="true">
              <span class="menu-toggle-line"></span>
              <span class="menu-toggle-line"></span>
              <span class="menu-toggle-line"></span>
            </span>
          </button>
        </div>

        <div class="mobile-menu" id="mobile-menu" data-mobile-menu hidden>
          <div
            class:list={[
              "mobile-menu-panel",
              { "no-nav": copy.nav.length === 0 },
            ]}
          >
            {
              copy.nav.length > 0 && (
                <nav class="mobile-nav" aria-label="Mobile">
                  {copy.nav.map((item) => (
                    <a href={item.href}>{item.label}</a>
                  ))}
                </nav>
              )
            }

            <div class="mobile-toolbar">
              <LanguageSwitch
                transition:persist="locale-switch-mobile"
                locale={locale}
                label={copy.languageSwitcherLabel}
              />
              <ThemeToggle themeLabel={copy.themeLabel} initialTheme="dark" />
              <a
                class="mobile-download"
                href={copy.headerCtaHref}
                target={cvLinkTarget}
                rel={cvLinkRel}
              >
                <DownloadIcon />
                <span>{copy.headerCta}</span>
              </a>
            </div>
          </div>
        </div>
      </header>

      <main id="content">
        <slot />
      </main>

      <footer class="site-footer reveal">
        <p class="footer-copy">© {currentYear} · {copy.footer}</p>
        <p class="footer-coords" aria-hidden="true">38.09°N 0.85°W</p>
        <p class="footer-interests">{copy.footerInterests}</p>
      </footer>
    </div>

    <script src="../scripts/ui.ts"></script>
    <script src="../scripts/site-spotlight.ts"></script>
  </body>
</html>
