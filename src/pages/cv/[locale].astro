---
import { cvCopy, type Locale } from "../../content/site";

export function getStaticPaths() {
  return [{ params: { locale: "en" } }, { params: { locale: "es" } }];
}

const locale = Astro.params.locale as Locale;
const cv = cvCopy[locale];
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <title>CV — José Miguel Torres Hernández</title>
    <style>
      @page {
        size: A4;
        margin: 0;
      }
      * {
        box-sizing: border-box;
      }
      body {
        margin: 0;
        font-family: "Noto Sans", "Arial", sans-serif;
        color: #111;
        background: #fff;
        font-size: 9.15pt;
        line-height: 1.34;
      }
      .page {
        width: 210mm;
        height: 297mm;
        display: grid;
        grid-template-columns: 58mm 1fr;
        background: #fff;
        break-after: auto;
        overflow: hidden;
      }
      .page + .page {
        break-before: page;
      }
      .side {
        background: #f0f0f0;
        padding: 17mm 8mm 13mm 10.5mm;
      }
      .main {
        padding: 17mm 13mm 13mm 12mm;
      }
      .mono {
        width: 31mm;
        height: 31mm;
        border: 1.3pt solid #111;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 20pt;
        font-weight: 800;
        letter-spacing: -0.06em;
        margin-bottom: 12mm;
      }
      .side-section {
        margin: 0 0 8.5mm 0;
      }
      .side-section.tight {
        margin-bottom: 6.8mm;
      }
      .side-title {
        margin: 0 0 3.7mm 0;
        padding-top: 2.4mm;
        border-top: 0.7pt solid #777;
        font-size: 7.1pt;
        line-height: 1;
        letter-spacing: 0.15em;
        text-transform: uppercase;
        color: #333;
        font-weight: 800;
      }
      .side p,
      .side a,
      .side li {
        font-size: 8.2pt;
        color: #111;
      }
      .side a {
        text-decoration: none;
        word-break: break-all;
      }
      .contact-line {
        margin: 0 0 2.2mm 0;
      }
      .muted {
        color: #666;
      }
      .label {
        display: block;
        font-size: 6.7pt;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: #666;
        font-weight: 800;
        margin: 3.1mm 0 0.8mm;
      }
      .stack p {
        margin: 0 0 2.3mm 0;
      }
      .small-list {
        margin: 0;
        padding-left: 0;
        list-style: none;
      }
      .small-list li {
        margin: 0 0 2.1mm 0;
      }
      h1 {
        font-size: 24.5pt;
        line-height: 0.95;
        margin: 0 0 3.2mm 0;
        font-weight: 820;
        letter-spacing: -0.055em;
      }
      .headline {
        font-size: 10.2pt;
        color: #333;
        font-weight: 700;
        margin: 0 0 2.6mm 0;
      }
      .linkbar {
        font-size: 8.3pt;
        color: #555;
        margin: 0 0 7.5mm 0;
      }
      .linkbar a {
        color: #111;
        text-decoration: none;
      }
      .section-title {
        margin: 7.4mm 0 3.5mm 0;
        padding-top: 2.6mm;
        border-top: 1.15pt solid #111;
        font-size: 7.2pt;
        line-height: 1;
        letter-spacing: 0.16em;
        text-transform: uppercase;
        color: #333;
        font-weight: 850;
      }
      .section-title.first {
        margin-top: 0;
      }
      .profile p {
        margin: 0 0 3mm 0;
      }
      .cards {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 3.1mm 5mm;
        margin-top: 1mm;
      }
      .card {
        border-top: 1pt solid #111;
        padding-top: 2.2mm;
      }
      .card-title {
        font-weight: 800;
        font-size: 9pt;
        margin-bottom: 1mm;
      }
      .card-copy {
        color: #444;
        font-size: 8.2pt;
      }
      .job {
        margin: 0 0 5mm 0;
      }
      .job + .job {
        margin-top: 5.5mm;
      }
      .job-head {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 5mm;
        margin-bottom: 1.3mm;
      }
      .job-title {
        font-weight: 850;
        font-size: 10.6pt;
        letter-spacing: -0.015em;
      }
      .company {
        font-weight: 700;
      }
      .meta {
        color: #666;
        font-size: 8.4pt;
        white-space: nowrap;
        padding-top: 0.8mm;
      }
      .role-note {
        margin: 0 0 2mm 0;
        color: #555;
        font-size: 8.4pt;
        font-style: italic;
      }
      ul.bullets {
        margin: 0;
        padding-left: 4.3mm;
      }
      ul.bullets li {
        margin: 0 0 1.65mm 0;
        padding-left: 0.6mm;
      }
      .two-col-focus {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 3.4mm 6mm;
        margin-top: 1mm;
      }
      .focus-item {
        border-top: 0.75pt solid #c8c8c8;
        padding-top: 2mm;
      }
      .focus-item strong {
        display: block;
        margin-bottom: 0.7mm;
      }
      .focus-item span {
        color: #444;
        font-size: 8.3pt;
      }
      .edu-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 5mm;
      }
      .edu-block {
        border-top: 0.75pt solid #c8c8c8;
        padding-top: 2mm;
      }
      .edu-block strong {
        display: block;
      }
      .footer {
        position: absolute;
        bottom: 8mm;
        color: #777;
        font-size: 7.3pt;
      }
      .main,
      .side {
        position: relative;
      }
    </style>
  </head>
  <body>
    <section class="page">
      <aside class="side">
        <div class="mono">JMT</div>
        <div class="side-section tight">
          <h3 class="side-title">{cv.labels.contact}</h3>
          <p class="contact-line">{cv.contact.location}</p>
          <p class="contact-line">
            <a href={`mailto:${cv.contact.email}`}>{cv.contact.email}</a>
          </p>
          <p class="contact-line">
            <a href={`tel:${cv.contact.phone.replace(/\s/g, "")}`}
              >{cv.contact.phone}</a
            >
          </p>
          <p class="contact-line">
            <a href={`https://www.linkedin.com/in/jmtrs/`}
              >{cv.contact.linkedin}</a
            >
          </p>
          <p class="contact-line">
            <a href={`https://github.com/jmtrs`}>{cv.contact.github}</a>
          </p>
        </div>
        <div class="side-section stack">
          <h3 class="side-title">{cv.labels.techStack}</h3>
          {
            cv.techStack.map((cat) => (
              <>
                <span class="label">{cat.name}</span>
                <p>{cat.items.join(", ")}.</p>
              </>
            ))
          }
        </div>
        <div class="side-section tight">
          <h3 class="side-title">{cv.labels.spokenLanguages}</h3>
          <ul class="small-list">
            {
              cv.spokenLanguages.map((lang) => (
                <li>
                  <strong>{lang.name}</strong>
                  <br />
                  <span class="muted">{lang.level}</span>
                </li>
              ))
            }
          </ul>
        </div>
        <div class="footer">José Miguel Torres Hernández</div>
      </aside>
      <main class="main">
        <h1>José Miguel Torres Hernández</h1>
        <p class="headline">{cv.headline}</p>
        <p class="linkbar">
          {cv.contact.location} ·
          <a href={`mailto:${cv.contact.email}`}>{cv.contact.email}</a> ·
          <a href={`tel:${cv.contact.phone.replace(/\s/g, "")}`}
            >{cv.contact.phone}</a
          > ·
          <a href="https://www.linkedin.com/in/jmtrs/">LinkedIn</a> ·
          <a href="https://github.com/jmtrs">GitHub</a>
        </p>

        <h2 class="section-title first">{cv.labels.profile}</h2>
        <div class="profile">
          {cv.profile.map((para) => <p>{para}</p>)}
        </div>

        <h2 class="section-title">{cv.labels.keyStrengths}</h2>
        <div class="cards">
          {
            cv.keyStrengths.map((s) => (
              <div class="card">
                <div class="card-title">{s.title}</div>
                <div class="card-copy">{s.description}</div>
              </div>
            ))
          }
        </div>

        <h2 class="section-title">{cv.labels.experience}</h2>
        <article class="job">
          <div class="job-head">
            <div>
              <span class="job-title">{cv.experience[0].role}</span> ·
              <span class="company">{cv.experience[0].company}</span>
              {
                cv.experience[0].location && (
                  <>
                    {" "}
                    · <span class="muted">{cv.experience[0].location}</span>
                  </>
                )
              }
            </div>
            <div class="meta">{cv.experience[0].period}</div>
          </div>
          {
            cv.experience[0].roleNote && (
              <p class="role-note">{cv.experience[0].roleNote}</p>
            )
          }
          <ul class="bullets">
            {cv.experience[0].bullets.map((b) => <li>{b}</li>)}
          </ul>
        </article>
        <div class="footer">{cv.labels.page1}</div>
      </main>
    </section>

    <section class="page">
      <aside class="side">
        <div class="mono">JMT</div>
        <div class="side-section">
          <h3 class="side-title">{cv.labels.certifications}</h3>
          <ul class="small-list">
            {
              cv.certifications.map((cert) => (
                <li>
                  <strong>{cert.name}</strong>
                  <br />
                  <span class="muted">{cert.detail}</span>
                </li>
              ))
            }
          </ul>
        </div>
        <div class="side-section">
          <h3 class="side-title">{cv.labels.education}</h3>
          <p>
            <strong>{cv.education.degree}</strong><br />
            <span class="muted"
              >{cv.education.school}, {cv.education.period}</span
            >
          </p>
        </div>
        <div class="side-section">
          <h3 class="side-title">{cv.labels.profileFit}</h3>
          <ul class="small-list">
            {cv.profileFit.map((role) => <li>{role}</li>)}
          </ul>
        </div>
        <div class="side-section">
          <h3 class="side-title">{cv.labels.links}</h3>
          <p class="contact-line">
            <a href="https://www.linkedin.com/in/jmtrs/"
              >{cv.contact.linkedin}</a
            >
          </p>
          <p class="contact-line">
            <a href="https://github.com/jmtrs">{cv.contact.github}</a>
          </p>
        </div>
        <div class="footer">José Miguel Torres Hernández</div>
      </aside>
      <main class="main">
        <h2 class="section-title first">{cv.labels.experienceContinued}</h2>
        {
          cv.experience.slice(1).map((job) => (
            <article class="job">
              <div class="job-head">
                <div>
                  <span class="job-title">{job.role}</span> ·{" "}
                  <span class="company">{job.company}</span>
                </div>
                <div class="meta">{job.period}</div>
              </div>
              {job.roleNote && <p class="role-note">{job.roleNote}</p>}
              <ul class="bullets">
                {job.bullets.map((b) => (
                  <li>{b}</li>
                ))}
              </ul>
            </article>
          ))
        }

        <h2 class="section-title">{cv.labels.focus}</h2>
        <div class="two-col-focus">
          {
            cv.focus.map((item) => (
              <div class="focus-item">
                <strong>{item.title}</strong>
                <span>{item.description}</span>
              </div>
            ))
          }
        </div>

        <h2 class="section-title">{cv.labels.eduCertLang}</h2>
        <div class="edu-grid">
          <div class="edu-block">
            <strong>{cv.education.degree}</strong>
            <span class="muted"
              >{cv.education.school}, {cv.education.period}</span
            >
          </div>
          <div class="edu-block">
            <strong>{cv.labels.certifications}</strong>
            <span class="muted">
              {
                cv.certifications
                  .map((c) => `${c.name}: ${c.detail}`)
                  .join("\n")
              }
            </span>
          </div>
          <div class="edu-block">
            <strong>{cv.labels.spokenLanguages}</strong>
            <span class="muted">
              {
                cv.spokenLanguages
                  .map((l) => `${l.name}: ${l.level}`)
                  .join("\n")
              }
            </span>
          </div>
        </div>
        <div class="footer">{cv.labels.page2}</div>
      </main>
    </section>
  </body>
</html>
