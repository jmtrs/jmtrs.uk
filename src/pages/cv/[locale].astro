---
import "@fontsource-variable/plus-jakarta-sans";
import { cvCopy, type Locale } from "../../content/site";

export function getStaticPaths() {
  return [{ params: { locale: "en" } }, { params: { locale: "es" } }];
}

const locale = Astro.params.locale as Locale;
const cv = cvCopy[locale];
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <title>CV — José Miguel Torres Hernández</title>
    <meta name="robots" content="noindex, nofollow" />
    <style is:inline>
      @page {
        size: A4;
        margin: 0;
      }
      * {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }
      body {
        margin: 0;
        font-family:
          "Plus Jakarta Sans Variable", "Avenir Next", "Helvetica Neue",
          sans-serif;
        color: #1c1c1e;
        background: #fff;
        font-size: 9.15pt;
        line-height: 1.34;
      }
      .page {
        width: 210mm;
        height: 297mm;
        display: grid;
        grid-template-columns: 58mm 1fr;
        background: #fff;
        break-after: auto;
        overflow: hidden;
      }
      .page + .page {
        break-before: page;
      }
      .side {
        background: #1a1a1a;
        padding: 16mm 8mm 13mm 10.5mm;
        box-shadow: inset 0 0 0 4px #fff;
      }
      .main {
        padding: 17mm 13mm 13mm 12mm;
        background: #fff;
      }
      .mono {
        width: 28mm;
        height: 28mm;
        border: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: -1.5mm auto 8.5mm auto;
        overflow: hidden;
      }
      .mono svg {
        width: 24mm;
        height: 24mm;
        display: block;
        transform: translate(-1.5mm, -2mm);
      }
      .side-section {
        margin: 0 0 8.5mm 0;
      }
      .side-section.tight {
        margin-bottom: 6.8mm;
      }
      .side-title {
        margin: 0 0 3.7mm 0;
        padding-top: 2.4mm;
        font-size: 7.1pt;
        line-height: 1;
        letter-spacing: 0.15em;
        text-transform: uppercase;
        color: #888;
        font-weight: 700;
      }
      .side p,
      .side a,
      .side li {
        font-size: 8.2pt;
        color: #d4d4d4;
      }
      .side a {
        text-decoration: none;
        word-break: break-all;
        color: #d4d4d4;
      }
      .contact-line {
        margin: 0 0 2.2mm 0;
      }
      .muted {
        color: #666;
      }
      .side .muted {
        color: #888;
      }
      .label {
        display: block;
        font-size: 6.7pt;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: #888;
        font-weight: 700;
        margin: 3.1mm 0 0.8mm;
      }
      .stack p {
        margin: 0 0 2.3mm 0;
      }
      .small-list {
        margin: 0;
        padding-left: 0;
        list-style: none;
      }
      .small-list li {
        margin: 0 0 2.1mm 0;
      }
      h1 {
        font-size: 23pt;
        line-height: 1;
        margin: 0 0 3.2mm 0;
        font-weight: 700;
        letter-spacing: -0.04em;
      }
      .headline {
        font-size: 9.6pt;
        color: #555;
        font-weight: 600;
        margin: 0 0 2.6mm 0;
      }
      .linkbar {
        font-size: 8.3pt;
        color: #555;
        margin: 0 0 7.5mm 0;
      }
      .linkbar a {
        color: #444;
        text-decoration: none;
      }
      .section-title {
        margin: 7.4mm 0 3.5mm 0;
        font-size: 7.2pt;
        line-height: 1;
        letter-spacing: 0.16em;
        text-transform: uppercase;
        color: #888;
        font-weight: 700;
      }
      .section-title.first {
        margin-top: 0;
      }
      .profile p {
        margin: 0 0 3mm 0;
      }
      .cards {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 3.1mm 5mm;
        margin-top: 1mm;
      }
      .card {
        padding-top: 2.2mm;
      }
      .card-title {
        font-weight: 700;
        font-size: 9pt;
        margin-bottom: 1mm;
      }
      .card-copy {
        color: #555;
        font-size: 8.2pt;
      }
      .job {
        margin: 0 0 5mm 0;
      }
      .job + .job {
        margin-top: 5.5mm;
      }
      .job-head {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 5mm;
        margin-bottom: 1.3mm;
      }
      .job-title {
        font-weight: 700;
        font-size: 10.2pt;
        letter-spacing: -0.01em;
      }
      .company {
        font-weight: 600;
      }
      .meta {
        color: #777;
        font-size: 8.4pt;
        white-space: nowrap;
        padding-top: 0.8mm;
      }
      .role-note {
        margin: 0 0 2mm 0;
        color: #555;
        font-size: 8.4pt;
        font-style: italic;
      }
      ul.bullets {
        margin: 0;
        padding-left: 4.3mm;
      }
      ul.bullets li {
        margin: 0 0 1.65mm 0;
        padding-left: 0.6mm;
      }
      .two-col-focus {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 3.4mm 6mm;
        margin-top: 1mm;
      }
      .focus-item {
        padding-top: 2mm;
      }
      .focus-item strong {
        display: block;
        margin-bottom: 0.7mm;
      }
      .focus-item span {
        color: #555;
        font-size: 8.3pt;
      }
      .edu-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 5mm;
      }
      .edu-block {
        padding-top: 2mm;
      }
      .edu-block strong {
        display: block;
      }
      .footer {
        position: absolute;
        bottom: 8mm;
        color: #aaa;
        font-size: 7.3pt;
      }
      .side .footer {
        color: #666;
      }
      .main,
      .side {
        position: relative;
      }
    </style>
  </head>
  <body>
    <svg
      aria-hidden="true"
      style="position:absolute;width:0;height:0;overflow:hidden"
    >
      <defs>
        <symbol id="cv-logo" viewBox="0 0 1254 1254">
