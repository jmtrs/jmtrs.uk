---
import "@fontsource-variable/plus-jakarta-sans";
import { cvCopy, type Locale } from "../../content/site";

export function getStaticPaths() {
  return [{ params: { locale: "en" } }, { params: { locale: "es" } }];
}

const locale = Astro.params.locale as Locale;
const cv = cvCopy[locale];
const primaryExperience = cv.experience[0];
const additionalExperience = cv.experience.slice(1);
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <title>CV — José Miguel Torres Hernández</title>
    <meta name="robots" content="noindex, nofollow" />
    <style is:inline>
      @page {
        size: A4;
        margin: 0;
      }
      * {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }
      body {
        font-family:
          "Plus Jakarta Sans Variable", "Avenir Next", "Helvetica Neue",
          sans-serif;
        color: #1b1b1d;
        background: #fff;
        font-size: 9.75pt;
        line-height: 1.4;
      }
      a {
        color: #1b1b1d;
        text-decoration: none;
      }
      .page {
        width: 210mm;
        height: 297mm;
        padding: 14.5mm 14.5mm 13.5mm;
        display: flex;
        flex-direction: column;
        gap: 5.6mm;
        overflow: hidden;
      }
      .page + .page {
        break-before: page;
      }
      header {
        position: relative;
        display: flex;
        flex-direction: column;
        gap: 1.9mm;
        padding-right: 38mm;
        padding-bottom: 2.8mm;
        border-bottom: 0.35mm solid #e7e7ea;
      }
      .header-top {
        display: block;
      }
      .brand-mark {
        position: absolute;
        margin-top: -10mm;
        top: 0;
        right: 0;
        width: 35mm;
        height: 35mm;
      }
      h1 {
        font-size: 24pt;
        line-height: 1.02;
        letter-spacing: -0.04em;
      }
      .headline {
        font-size: 9.9pt;
        font-weight: 700;
        color: #333;
        white-space: nowrap;
      }
      .contact-bar {
        font-size: 9pt;
        color: #4d4d52;
      }
      .section-title {
        font-size: 7.2pt;
        line-height: 1;
        letter-spacing: 0.16em;
        text-transform: uppercase;
        color: #777;
        font-weight: 700;
        margin-bottom: 2.6mm;
      }
      .profile p + p,
      .stack-list p + p,
      .summary-list li + li,
      .focus-list li + li,
      .job + .job,
      .meta-list li + li,
      .cert-list li + li {
        margin-top: 2.2mm;
      }
      .stack-list p,
      .profile p,
      .job p,
      .meta-copy p,
      .meta-copy li {
        color: #2f2f33;
      }
      .stack-list strong,
      .meta-copy strong {
        color: #121214;
      }
      .summary-list,
      .job-list,
      .focus-list,
      .meta-list,
      .cert-list {
        padding-left: 4.2mm;
      }
      .summary-list li,
      .job-list li,
      .focus-list li,
      .meta-list li,
      .cert-list li {
        padding-left: 0.7mm;
      }
      .job {
        margin-top: 1.1mm;
      }
      .job-head {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: 4mm;
        margin-bottom: 1.8mm;
      }
      .job-role {
        font-weight: 700;
        font-size: 10.55pt;
      }
      .job-company {
        font-weight: 600;
      }
      .job-meta {
        font-size: 8.65pt;
        color: #666;
        white-space: nowrap;
      }
      .job-note {
        margin-bottom: 2.2mm;
        color: #4d4d52;
        font-style: italic;
        font-size: 8.85pt;
      }
      .profile-fit {
        color: #2f2f33;
      }
      .compact-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 4mm;
      }
      .meta-copy {
        display: flex;
        flex-direction: column;
        gap: 1.6mm;
      }
      .meta-copy ul {
        margin: 0;
      }
    </style>
  </head>
  <body>
    <section class="page">
      <header>
        <div class="header-top">
          <h1>José Miguel Torres Hernández</h1>
          <img
            class="brand-mark"
            src="../../logo.svg"
            alt=""
            aria-hidden="true"
          />
        </div>
        <p class="headline">{cv.headline}</p>
        <p class="contact-bar">
          {cv.contact.location} ·
          {cv.contact.phone && <>{cv.contact.phone} · </>}
          <a href={`mailto:${cv.contact.email}`}>{cv.contact.email}</a> ·
          <a href="https://www.linkedin.com/in/jmtrs/">{cv.contact.linkedin}</a> ·
          <a href="https://github.com/jmtrs">{cv.contact.github}</a>
        </p>
      </header>

      <section>
        <h2 class="section-title">{cv.labels.profile}</h2>
        <div class="profile">
          {cv.profile.map((paragraph) => <p>{paragraph}</p>)}
        </div>
      </section>

      <section>
        <h2 class="section-title">{cv.labels.keyStrengths}</h2>
        <ul class="summary-list">
          {
            cv.keyStrengths.map((strength) => (
              <li>
                <strong>{strength.title}:</strong> {strength.description}
              </li>
            ))
          }
        </ul>
      </section>

      <section>
        <h2 class="section-title">{cv.labels.techStack}</h2>
        <div class="stack-list">
          {
            cv.techStack.map((category) => (
              <p>
                <strong>{category.name}:</strong> {category.items.join(", ")}.
              </p>
            ))
          }
        </div>
      </section>

      <section>
        <h2 class="section-title">{cv.labels.experience}</h2>
        <article class="job">
          <div class="job-head">
            <div>
              <span class="job-role">{primaryExperience.role}</span> ·{" "}
              <span class="job-company">{primaryExperience.company}</span>
              {
                primaryExperience.location && (
                  <>
                    {" "}
                    · <span>{primaryExperience.location}</span>
                  </>
                )
              }
            </div>
            <div class="job-meta">{primaryExperience.period}</div>
          </div>
          {
            primaryExperience.roleNote && (
              <p class="job-note">{primaryExperience.roleNote}</p>
            )
          }
          <ul class="job-list">
            {primaryExperience.bullets.map((bullet) => <li>{bullet}</li>)}
          </ul>
        </article>
      </section>
    </section>

    <section class="page">
      <section>
        <h2 class="section-title">{cv.labels.experience}</h2>
        {
          additionalExperience.map((job) => (
            <article class="job">
              <div class="job-head">
                <div>
                  <span class="job-role">{job.role}</span> ·{" "}
                  <span class="job-company">{job.company}</span>
                  {job.location && (
                    <>
                      {" "}
                      · <span>{job.location}</span>
                    </>
                  )}
                </div>
                <div class="job-meta">{job.period}</div>
              </div>
              {job.roleNote && <p class="job-note">{job.roleNote}</p>}
              <ul class="job-list">
                {job.bullets.map((bullet) => (
                  <li>{bullet}</li>
                ))}
              </ul>
            </article>
          ))
        }
      </section>

      <section>
        <h2 class="section-title">{cv.labels.focus}</h2>
        <ul class="focus-list">
          {
            cv.focus.map((item) => (
              <li>
                <strong>{item.title}:</strong> {item.description}
              </li>
            ))
          }
        </ul>
      </section>

      <section>
        <h2 class="section-title">{cv.labels.eduCertLang}</h2>
        <div class="compact-grid">
          <div class="meta-copy">
            <p>
              <strong>{cv.labels.education}:</strong>
              {cv.education.degree}.{" "}
              {cv.education.school}, {cv.education.period}.
            </p>
          </div>
          <div class="meta-copy">
            <p><strong>{cv.labels.certifications}:</strong></p>
            <ul class="cert-list">
              {
                cv.certifications.map((certification) => (
                  <li>
                    {certification.name} · {certification.detail}
                  </li>
                ))
              }
            </ul>
          </div>
          <div class="meta-copy">
            <p><strong>{cv.labels.spokenLanguages}:</strong></p>
            <ul class="meta-list">
              {
                cv.spokenLanguages.map((language) => (
                  <li>
                    {language.name} · {language.level}
                  </li>
                ))
              }
            </ul>
          </div>
        </div>
      </section>

      <section>
        <h2 class="section-title">{cv.labels.profileFit}</h2>
        <p class="profile-fit">{cv.profileFit.join(" · ")}</p>
      </section>
    </section>
  </body>
</html>
