    </svg>
    <section class="page">
      <aside class="side">
        <div class="mono">
          <svg viewBox="0 0 1254 1254" aria-hidden="true"
            ><use href="#cv-logo"></use></svg
          >
        </div>
        <div class="side-section tight">
          <h3 class="side-title">{cv.labels.contact}</h3>
          <p class="contact-line">{cv.contact.location}</p>
          <p class="contact-line">
            <a href={`mailto:${cv.contact.email}`}>{cv.contact.email}</a>
          </p>
          <p class="contact-line">
            <a href={`tel:${cv.contact.phone.replace(/\s/g, "")}`}
              >{cv.contact.phone}</a
            >
          </p>
          <p class="contact-line">
            <a href={`https://www.linkedin.com/in/jmtrs/`}
              >{cv.contact.linkedin}</a
            >
          </p>
          <p class="contact-line">
            <a href={`https://github.com/jmtrs`}>{cv.contact.github}</a>
          </p>
        </div>
        <div class="side-section stack">
          <h3 class="side-title">{cv.labels.techStack}</h3>
          {
            cv.techStack.map((cat) => (
              <>
                <span class="label">{cat.name}</span>
                <p>{cat.items.join(", ")}.</p>
              </>
            ))
          }
        </div>
        <div class="side-section tight">
          <h3 class="side-title">{cv.labels.spokenLanguages}</h3>
          <ul class="small-list">
            {
              cv.spokenLanguages.map((lang) => (
                <li>
                  <strong>{lang.name}</strong>
                  <br />
                  <span class="muted">{lang.level}</span>
                </li>
              ))
            }
          </ul>
        </div>
        <div class="footer">José Miguel Torres Hernández</div>
      </aside>
      <main class="main">
        <h1>José Miguel Torres Hernández</h1>
        <p class="headline">{cv.headline}</p>
        <p class="linkbar">
          {cv.contact.location} ·
          <a href={`mailto:${cv.contact.email}`}>{cv.contact.email}</a> ·
          <a href={`tel:${cv.contact.phone.replace(/\s/g, "")}`}
            >{cv.contact.phone}</a
          > ·
          <a href="https://www.linkedin.com/in/jmtrs/">LinkedIn</a> ·
          <a href="https://github.com/jmtrs">GitHub</a>
        </p>

        <h2 class="section-title first">{cv.labels.profile}</h2>
        <div class="profile">
          {cv.profile.map((para) => <p>{para}</p>)}
        </div>

        <h2 class="section-title">{cv.labels.keyStrengths}</h2>
        <div class="cards">
          {
            cv.keyStrengths.map((s) => (
              <div class="card">
                <div class="card-title">{s.title}</div>
                <div class="card-copy">{s.description}</div>
              </div>
            ))
          }
        </div>

        <h2 class="section-title">{cv.labels.experience}</h2>
        <article class="job">
          <div class="job-head">
            <div>
              <span class="job-title">{cv.experience[0].role}</span> ·
              <span class="company">{cv.experience[0].company}</span>
              {
                cv.experience[0].location && (
                  <>
                    {" "}
                    · <span class="muted">{cv.experience[0].location}</span>
                  </>
                )
              }
            </div>
            <div class="meta">{cv.experience[0].period}</div>
          </div>
          {
            cv.experience[0].roleNote && (
              <p class="role-note">{cv.experience[0].roleNote}</p>
            )
          }
          <ul class="bullets">
            {cv.experience[0].bullets.map((b) => <li>{b}</li>)}
          </ul>
        </article>
        <div class="footer">{cv.labels.page1}</div>
      </main>
    </section>

    <section class="page">
      <aside class="side">
        <div class="mono">
          <svg viewBox="0 0 1254 1254" aria-hidden="true"
            ><use href="#cv-logo"></use></svg
          >
        </div>
        <div class="side-section">
          <h3 class="side-title">{cv.labels.certifications}</h3>
          <ul class="small-list">
            {
              cv.certifications.map((cert) => (
                <li>
                  <strong>{cert.name}</strong>
                  <br />
                  <span class="muted">{cert.detail}</span>
                </li>
              ))
            }
          </ul>
        </div>
        <div class="side-section">
          <h3 class="side-title">{cv.labels.education}</h3>
          <p>
            <strong>{cv.education.degree}</strong><br />
            <span class="muted"
              >{cv.education.school}, {cv.education.period}</span
            >
          </p>
        </div>
        <div class="side-section">
          <h3 class="side-title">{cv.labels.profileFit}</h3>
          <ul class="small-list">
            {cv.profileFit.map((role) => <li>{role}</li>)}
          </ul>
        </div>
        <div class="side-section">
          <h3 class="side-title">{cv.labels.links}</h3>
          <p class="contact-line">
            <a href="https://www.linkedin.com/in/jmtrs/"
              >{cv.contact.linkedin}</a
            >
          </p>
          <p class="contact-line">
            <a href="https://github.com/jmtrs">{cv.contact.github}</a>
          </p>
        </div>
        <div class="footer">José Miguel Torres Hernández</div>
      </aside>
      <main class="main">
        <h2 class="section-title first">{cv.labels.experienceContinued}</h2>
        {
          cv.experience.slice(1).map((job) => (
            <article class="job">
              <div class="job-head">
                <div>
                  <span class="job-title">{job.role}</span> ·{" "}
                  <span class="company">{job.company}</span>
                </div>
                <div class="meta">{job.period}</div>
              </div>
              {job.roleNote && <p class="role-note">{job.roleNote}</p>}
              <ul class="bullets">
                {job.bullets.map((b) => (
                  <li>{b}</li>
                ))}
              </ul>
            </article>
          ))
        }

        <h2 class="section-title">{cv.labels.focus}</h2>
        <div class="two-col-focus">
          {
            cv.focus.map((item) => (
              <div class="focus-item">
                <strong>{item.title}</strong>
                <span>{item.description}</span>
              </div>
            ))
          }
        </div>

        <h2 class="section-title">{cv.labels.eduCertLang}</h2>
        <div class="edu-grid">
          <div class="edu-block">
            <strong>{cv.education.degree}</strong>
            <span class="muted"
              >{cv.education.school}, {cv.education.period}</span
            >
          </div>
          <div class="edu-block">
            <strong>{cv.labels.certifications}</strong>
            <span class="muted">
              {
                cv.certifications
                  .map((c) => `${c.name}: ${c.detail}`)
                  .join("\n")
              }
            </span>
          </div>
          <div class="edu-block">
            <strong>{cv.labels.spokenLanguages}</strong>
            <span class="muted">
              {
                cv.spokenLanguages
                  .map((l) => `${l.name}: ${l.level}`)
                  .join("\n")
              }
            </span>
          </div>
        </div>
        <div class="footer">{cv.labels.page2}</div>
      </main>
    </section>
  </body>
</html>
