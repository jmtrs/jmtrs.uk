<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>jmtrs.uk</title>
    <meta name="robots" content="noindex, follow" />
    <script is:inline>
      (() => {
        const localeKey = "jmtrs-locale";
        const storedLocale = window.localStorage.getItem(localeKey);
        const nextLocale = storedLocale === "es" ? "es" : "en";
        window.location.replace(`/${nextLocale}`);
      })();
    </script>
    <noscript>
      <meta http-equiv="refresh" content="0; url=/en" />
    </noscript>
  </head>
  <body></body>
</html>
