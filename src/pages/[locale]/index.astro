---
import "../../styles/home.css";
import BaseLayout from "../../layouts/BaseLayout.astro";
import ContactCard from "../../components/ContactCard.astro";
import { siteCopy, type Locale } from "../../content/site";

export function getStaticPaths() {
  return [{ params: { locale: "en" } }, { params: { locale: "es" } }];
}

const locale = Astro.params.locale as Locale;
const copy = siteCopy[locale];
const isCvLink = (href: string) =>
  href.startsWith("/cv/") && href.endsWith(".pdf");

if (!copy) {
  throw new Error(`Unsupported locale: ${locale}`);
}
---

<BaseLayout locale={locale} copy={copy}>
  <div class="home-stage">
    <section class="hero">
      <div class="hero-copy">
        <h1
          class="hero-title reveal"
          data-hero-title
          data-hero-effect="full"
          style="--delay: 80ms;"
        >
          {
            copy.hero.title.map((line) => (
              <span
                class="hero-line"
                data-text={line}
                style={`--characters:${Array.from(line).length};`}
              >
                <span class="hero-line-text">{line}</span>
                <span class="hero-line-overlay" aria-hidden="true">
                  {line}
                </span>
                <span class="hero-mobile-cursor" aria-hidden="true" />
              </span>
            ))
          }
        </h1>
        <p class="hero-intro reveal" style="--delay: 220ms;">
          {copy.hero.intro}
        </p>
        <p class="hero-summary reveal" style="--delay: 340ms;">
          {copy.hero.summary}
        </p>
        <div class="action-row reveal" style="--delay: 460ms;">
          {
            copy.hero.actions.map((action) =>
              action.href === "#contact-modal" ? (
                <button
                  class={`button ${action.variant}`}
                  type="button"
                  data-contact-open
                  aria-haspopup="dialog"
                  aria-controls="contact-modal"
                >
                  <span>{action.label}</span>
                  <span class="button-emblem" aria-hidden="true">
                    →
                  </span>
                </button>
              ) : (
                <a
                  class={`button ${action.variant}`}
                  href={action.href}
                  target={isCvLink(action.href) ? "_blank" : undefined}
                  rel={isCvLink(action.href) ? "noreferrer" : undefined}
                >
                  <span>{action.label}</span>
                  <span class="button-emblem" aria-hidden="true">
                    {action.variant === "primary" ? "↓" : "→"}
                  </span>
                </a>
              ),
            )
          }
        </div>
      </div>
    </section>
  </div>

  <div class="contact-modal" data-contact-modal hidden>
    <div class="contact-modal-backdrop" data-contact-close aria-hidden="true">
    </div>
    <div class="contact-modal-shell">
      <div
        class="contact-modal-panel"
        id="contact-modal"
        role="dialog"
        aria-modal="true"
        aria-labelledby="contact-modal-title"
        aria-describedby="contact-modal-intro"
        tabindex="-1"
      >
        <div class="contact-modal-header">
          <div class="contact-modal-heading">
            <p class="contact-modal-kicker">{copy.contact.eyebrow}</p>
            <h2 id="contact-modal-title">{copy.contact.title}</h2>
            <p id="contact-modal-intro">{copy.contact.intro}</p>
          </div>
          <button
            class="contact-modal-close"
            type="button"
            data-contact-close
            aria-label={copy.contact.closeLabel}
          >
            <span aria-hidden="true">×</span>
          </button>
        </div>

        <div class="contact-modal-grid">
          {copy.contact.links.map((link) => <ContactCard link={link} />)}
        </div>
      </div>
    </div>
  </div>
</BaseLayout>
