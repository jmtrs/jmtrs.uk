---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SectionHeading from "../../components/SectionHeading.astro";
import { siteCopy, type Locale } from "../../content/site";

export function getStaticPaths() {
  return [{ params: { locale: "en" } }, { params: { locale: "es" } }];
}

const locale = Astro.params.locale as Locale;
const copy = siteCopy[locale];

if (!copy) {
  throw new Error(`Unsupported locale: ${locale}`);
}
---

<BaseLayout locale={locale} copy={copy}>
  <section class="hero">
    <div class="hero-copy">
      <p class="hero-eyebrow reveal">{copy.hero.eyebrow}</p>
      <h1 class="reveal">{copy.hero.title}</h1>
      <p class="hero-intro reveal">{copy.hero.intro}</p>
      <p class="hero-summary reveal">{copy.hero.summary}</p>

      <div class="action-row reveal">
        {
          copy.hero.actions.map((action) => (
            <a class={`button ${action.variant}`} href={action.href}>
              {action.label}
            </a>
          ))
        }
      </div>
    </div>

    <aside class="hero-panel reveal">
      <div class="hero-panel-inner">
        {
          copy.hero.stats.map((stat) => (
            <div class="stat-item">
              <span>{stat.label}</span>
              <strong>{stat.value}</strong>
            </div>
          ))
        }
      </div>
    </aside>
  </section>

  <section id="about" class="content-section">
    <SectionHeading eyebrow={copy.about.eyebrow} title={copy.about.title} />
    <div class="copy-grid">
      {
        copy.about.paragraphs.map((paragraph) => (
          <p class="reveal">{paragraph}</p>
        ))
      }
    </div>
  </section>

  <section id="experience" class="content-section">
    <SectionHeading
      eyebrow={copy.experience.eyebrow}
      title={copy.experience.title}
      intro={copy.experience.intro}
    />
    <div class="timeline">
      {
        copy.experience.items.map((item) => (
          <article class="timeline-card reveal">
            <div class="timeline-heading">
              <div>
                <p class="role">{item.role}</p>
                <p class="company">{item.company}</p>
              </div>
              <div class="timeline-meta">
                <span>{item.location}</span>
                <strong>{item.period}</strong>
              </div>
            </div>
            <p class="timeline-summary">{item.summary}</p>
            <ul>
              {item.bullets.map((bullet) => (
                <li>{bullet}</li>
              ))}
            </ul>
          </article>
        ))
      }
    </div>
  </section>

  <section id="projects" class="content-section">
    <SectionHeading
      eyebrow={copy.projects.eyebrow}
      title={copy.projects.title}
      intro={copy.projects.intro}
    />
    <div class="card-grid">
      {
        copy.projects.items.map((project) => (
          <article class="project-card reveal">
            <h3>{project.title}</h3>
            <p>{project.description}</p>
            <ul class="tag-list">
              {project.tags.map((tag) => (
                <li>{tag}</li>
              ))}
            </ul>
          </article>
        ))
      }
    </div>
  </section>

  <section id="strengths" class="content-section">
    <SectionHeading
      eyebrow={copy.strengths.eyebrow}
      title={copy.strengths.title}
    />
    <div class="card-grid strengths-grid">
      {
        copy.strengths.items.map((item) => (
          <article class="strength-card reveal">
            <h3>{item.title}</h3>
            <p>{item.description}</p>
          </article>
        ))
      }
    </div>
  </section>

  <section class="content-section split-section">
    <div>
      <SectionHeading
        eyebrow={copy.workingStyle.eyebrow}
        title={copy.workingStyle.title}
      />
      <ul class="plain-list reveal">
        {copy.workingStyle.bullets.map((bullet) => <li>{bullet}</li>)}
      </ul>
    </div>

    <div class="downloads-panel">
      <SectionHeading
        eyebrow={copy.downloads.eyebrow}
        title={copy.downloads.title}
        intro={copy.downloads.intro}
      />
      <div class="download-actions reveal">
        {
          copy.downloads.items.map((item) => (
            <a class={`button ${item.variant}`} href={item.href}>
              {item.label}
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <section id="contact" class="content-section contact-section">
    <SectionHeading
      eyebrow={copy.contact.eyebrow}
      title={copy.contact.title}
      intro={copy.contact.intro}
    />
    <div class="contact-grid">
      {
        copy.contact.links.map((link) => (
          <a class="contact-card reveal" href={link.href}>
            <span>{link.label}</span>
            <strong>{link.value}</strong>
          </a>
        ))
      }
    </div>
  </section>
</BaseLayout>
